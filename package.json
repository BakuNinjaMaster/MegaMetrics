{
  "name": "metametric",
  "version": "0.1.0",
  "description": "Project MetaMetric - Pokemon Champions companion app",
  "main": "src/main/index.js",
  "scripts": {
    "dev": "concurrently \"vite --config vite.config.js --port 5173\" \"wait-on http://localhost:5173 && cross-env NODE_ENV=development electron .\"",
    "build": "vite build --config vite.config.js && electron-builder",
    "start": "electron ."
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.0",
    "concurrently": "^8.2.0",
    "cross-env": "^7.0.3",
    "electron": "^28.2.0",
    "electron-builder": "^24.13.3",
    "vite": "^5.0.0",
    "wait-on": "^7.2.0"
  },
  "dependencies": {
    "@smogon/calc": "^0.9.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "sharp": "^0.33.0",
    "tesseract.js": "^5.0.3"
  },
  "build": {
    "appId": "com.metametric.app",
    "productName": "MetaMetric",
    "win": {
      "target": "nsis",
      "icon": "src/renderer/assets/icon.ico"
    },
    "files": [
      "dist/**/*",
      "src/main/**/*"
    ],
    "directories": {
      "output": "release"
    }
  }
}